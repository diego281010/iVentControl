<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox prefHeight="600.0" prefWidth="900.0" spacing="15.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.proyectofinalpoo.controller.UsuariosController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <HBox alignment="CENTER_LEFT">
            <children>
                <Label text="USUARIOS">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <ImageView fitHeight="90.0" fitWidth="137.0" pickOnBounds="true" preserveRatio="true" />
            </children>
        </HBox>
        <HBox spacing="20.0">
            <children>
                <Button mnemonicParsing="false" onAction="#cambiarUsuarioAdmin" text="Hacer administrador" />
            <Button layoutX="10.0" layoutY="10.0" mnemonicParsing="false" onAction="#cambiarUsuarioCliente" text="Hacer cliente" />
            <Button layoutX="154.0" layoutY="10.0" mnemonicParsing="false" onAction="#cambiarUsuarioVendedor" text="Hacer vendedor" />
                <Button mnemonicParsing="false" onAction="#eliminarUsuario" text="Eliminar" />
            <Button layoutX="380.0" layoutY="10.0" mnemonicParsing="false" onAction="#reactivarUsuario" text="Reactivar" />
                <Button mnemonicParsing="false" onAction="#refrescarUsuarios" text="Refrescar" />
            </children>
        </HBox>
        <HBox alignment="CENTER" spacing="20.0">
            <children>
                <TextField fx:id="txtBuscar" promptText="Buscar usuario..." HBox.hgrow="ALWAYS" />
                <Label text="Usuario seleccionado:" />
                <TextField fx:id="txtUsuarioSeleccionado" editable="false" />
            </children>
        </HBox>
        <TableView fx:id="tbUsuarios" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" prefWidth="75.0" text="ID" />
                <TableColumn fx:id="colNombre" prefWidth="120.0" text="Nombre" />
                <TableColumn fx:id="colApellido" prefWidth="120.0" text="Apellido" />
                <TableColumn fx:id="colUsuario" prefWidth="120.0" text="Usuario" />
                <TableColumn fx:id="colCorreo" prefWidth="180.0" text="Correo" />
                <TableColumn fx:id="colRol" prefWidth="120.0" text="Rol" />
                <TableColumn fx:id="colEstado" prefWidth="100.0" text="Estado" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </children>
</VBox>
