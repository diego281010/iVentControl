<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<AnchorPane prefHeight="620.0"
            prefWidth="440.0"
            styleClass="auth-pane"
            stylesheets="@../css/styles.css"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.proyectofinalpoo.controller.RegistroClienteController">

    <children>

        <VBox alignment="CENTER" spacing="4" layoutX="0.0" layoutY="18.0"
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <children>
                <ImageView fitHeight="80.0" preserveRatio="true">
                    <image>
                        <Image url="@../images/logo.png" />
                    </image>
                    <viewport>
                        <Rectangle2D minX="550" minY="117" width="307" height="361" />
                    </viewport>
                </ImageView>
                <Label text="Registro de cliente nuevo" styleClass="titulo-acento">
                    <font>
                        <javafx.scene.text.Font size="18.0" />
                    </font>
                </Label>
            </children>
        </VBox>

        <VBox layoutX="50.0" layoutY="140.0" spacing="14.0" prefWidth="340.0">
            <children>

                <VBox spacing="4.0">
                    <Label text="Nombre" />
                    <TextField fx:id="txtNombreCliente" prefHeight="38.0" />
                </VBox>

                <VBox spacing="4.0">
                    <Label text="Apellido" />
                    <TextField fx:id="txtApellidoCliente" prefHeight="38.0" />
                </VBox>

                <VBox spacing="4.0">
                    <Label text="Usuario" />
                    <TextField fx:id="txtUsuarioCliente" prefHeight="38.0" />
                </VBox>

                <VBox spacing="4.0">
                    <Label text="Correo" />
                    <TextField fx:id="txtCorreoCliente" prefHeight="38.0" />
                </VBox>

                <VBox spacing="4.0">
                    <Label text="Contraseña" />
                    <PasswordField fx:id="txtPasswordCliente" prefHeight="38.0" />
                </VBox>

                <VBox spacing="4.0">
                    <Label text="Confirmar contraseña" />
                    <PasswordField fx:id="txtConfirmarPasswordCliente" prefHeight="38.0" />
                </VBox>

                <HBox spacing="12.0" alignment="CENTER_RIGHT">
                    <children>
                        <Button fx:id="btnVolverLogin" styleClass="button-secondary" text="Volver" onAction="#volver" />
                        <Button fx:id="btnRegistrarCliente" text="Registrarme" onAction="#registrar" />
                    </children>
                </HBox>

            </children>
        </VBox>

    </children>

</AnchorPane>