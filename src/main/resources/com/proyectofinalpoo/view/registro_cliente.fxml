<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="480.0"
            prefWidth="420.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.proyectofinalpoo.controller.RegistroClienteController">

    <children>

        <Label layoutX="90.0"
               layoutY="25.0"
               text="Registro de cliente nuevo"
               style="-fx-font-size: 16px; -fx-font-weight: bold;" />

        <VBox layoutX="40.0" layoutY="70.0" spacing="12.0" prefWidth="340.0">
            <children>

                <VBox spacing="4.0">
                    <Label text="Nombre" />
                    <TextField fx:id="txtNombreCliente" />
                </VBox>

                <VBox spacing="4.0">
                    <Label text="Apellido" />
                    <TextField fx:id="txtApellidoCliente" />
                </VBox>

                <VBox spacing="4.0">
                    <Label text="Usuario" />
                    <TextField fx:id="txtUsuarioCliente" />
                </VBox>

                <VBox spacing="4.0">
                    <Label text="Correo" />
                    <TextField fx:id="txtCorreoCliente" />
                </VBox>

                <VBox spacing="4.0">
                    <Label text="Contraseña" />
                    <PasswordField fx:id="txtPasswordCliente" />
                </VBox>

                <VBox spacing="4.0">
                    <Label text="Confirmar contraseña" />
                    <PasswordField fx:id="txtConfirmarPasswordCliente" />
                </VBox>

                <HBox spacing="12.0" alignment="CENTER_RIGHT">
                    <children>
                        <Button fx:id="btnVolverLogin" text="Volver" onAction="#volver" />
                        <Button fx:id="btnRegistrarCliente" text="Registrarme" onAction="#registrar" />
                    </children>
                </HBox>

            </children>
        </VBox>

    </children>

</AnchorPane>